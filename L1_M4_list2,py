def match_words(words):
    ctr=0
    lst=[]
    for word in words:
        if len(word)>1 and word[0]==word[-1]:
            ctr+=1
            lst.append(word)
    print("list of the worc with same front and last are: ",lst)
    return ctr
count=match_words(["cfc","aba","1221","abd","124"])
print("the count is: ",count)